<view class="dna-page page-shell result-page">
  <view class="page-header">
    <view class="topbar">
      <view class="brand">
        <image class="logo-mini" src="/assets/logo.png"/>
        <view><view class="brand-title">我的交易DNA</view><view class="brand-sub">TradeDNA Report</view></view>
      </view>
      <view class="pill">报告</view>
    </view>
  </view>

  <view class="page-scroll"><view class="safe">
  <view wx:if="{{result.validityWarnings && result.validityWarnings.length}}" class="validity-banner">
    <view class="validity-banner-ico">⚠</view>
    <view class="validity-banner-body">
      <view class="validity-banner-title">答题模式提示</view>
      <view class="validity-banner-item" wx:for="{{result.validityWarnings}}" wx:key="type">· {{item.text}}</view>
    </view>
  </view>

  <view class="glass-card result-main">
    <view class="result-glow"></view>
    <view class="result-code">{{result.code}}</view>
    <view class="type-name">{{p.name}}</view>
    <view class="badge">{{p.tag}}</view>
    <view class="desc result-desc">{{p.summary}}</view>
  </view>

  <view wx:if="{{result.divergence && result.divergence.length}}" class="glass-card divergence-card">
    <view class="divergence-head">
      <view class="divergence-ico">⚠</view>
      <view>
        <view class="divergence-title">主测与行为的背离</view>
        <view class="divergence-sub">主测结果是 <text class="gold">{{result.cognitiveCode}}</text>，行为题表现更接近 <text class="gold">{{result.behaviorCode}}</text></view>
      </view>
    </view>
    <view class="divergence-row" wx:for="{{result.divergence}}" wx:key="dimension">
      <view class="divergence-dim">{{item.dimName}}</view>
      <view class="divergence-flow">
        <text class="divergence-cog">{{item.cognitive}}</text>
        <text class="divergence-arrow">→</text>
        <text class="divergence-beh">{{item.behavior}}</text>
      </view>
    </view>
    <view class="divergence-note">「主测答题」与「行为情境题」之间存在差异。这本身不是错误，但值得在复盘时多关注。</view>
  </view>

  <view class="section-title">交易体系匹配雷达</view>
  <view class="glass-card radar-card">
    <canvas type="2d" id="radarCanvas" class="radar-canvas"></canvas>
  </view>

  <view class="glass-card follow-card">
    <view class="follow-left">
      <view class="follow-eyebrow">领取你的完整解读</view>
      <view class="follow-title"><text class="gold">{{result.code}}</text> 人格深度报告</view>
      <view class="follow-sub">5000 字详解 · 实战案例 · 适配策略</view>
      <view class="follow-step">关注后回复 <text class="gold">{{result.code}}</text></view>
      <view class="btn-follow-oac" bindtap="followOfficial">+ 关注公众号</view>
    </view>
    <view class="follow-qr" bindtap="followOfficial">
      <image class="follow-qr-img" src="/assets/qrcode.jpg" mode="aspectFill" show-menu-by-longpress="{{true}}"/>
      <view class="follow-qr-tag">量化新手村</view>
      <view class="follow-qr-tip">长按识别二维码</view>
    </view>
  </view>

  <view class="section-title" wx:if="{{mentorList.length || p.mentorEmpty}}">名人对照 · 你的交易导师</view>

  <!-- 多导师列表 -->
  <block wx:if="{{mentorList.length}}">
    <view class="glass-card mentor-card" wx:for="{{mentorList}}" wx:key="name">
      <view class="mentor-head">
        <view class="mentor-avatar {{item.avatar?'mentor-avatar-img-wrap':''}}">
          <image wx:if="{{item.avatar}}" class="mentor-avatar-img" src="{{item.avatar}}" mode="aspectFill"/>
          <text wx:else>{{item.initial}}</text>
        </view>
        <view class="mentor-info">
          <view class="mentor-name">{{item.name}}</view>
          <view class="mentor-title">{{item.title}}</view>
        </view>
      </view>
      <view class="mentor-bio">{{item.bio}}</view>
      <view class="mentor-quote">「{{item.lesson}}」</view>
    </view>
  </block>

  <!-- XECF：无导师的警醒文案 -->
  <view class="glass-card mentor-card mentor-empty-card" wx:elif="{{p.mentorEmpty}}">
    <view class="mentor-empty-title">{{p.mentorEmpty.title}}</view>
    <view class="mentor-empty-body">{{p.mentorEmpty.body}}</view>
  </view>

  <view class="section-title">核心特性</view>
  <view class="glass-card list-card">
    <view class="list-item" wx:for="{{p.traits}}" wx:key="*this">
      <view class="check">✓</view><view>{{item}}</view>
    </view>
  </view>

  <view class="section-title" wx:if="{{p.advice}}">行动建议</view>
  <view class="glass-card list-card" wx:if="{{p.advice}}">
    <view class="list-item" wx:for="{{p.advice}}" wx:key="*this">
      <view class="dot"></view><view>{{item}}</view>
    </view>
  </view>

  <view class="section-title">推荐交易体系</view>
  <view class="glass-card list-card">
    <view class="score-row" wx:for="{{scoreList}}" wx:key="name">
      <view class="score-top"><text>{{item.name}}</text><text class="gold-num">{{item.value}} ★</text></view>
      <view class="score-bar"><view class="score-fill" style="width:{{item.value*20}}%;"></view></view>
    </view>
  </view>

  <view class="section-title">优势 & 风险</view>
  <view class="grid2">
    <view class="mini-card">
      <view class="mini-title">⚔ 优势</view>
      <view class="mini-text" wx:for="{{p.traits}}" wx:key="*this">• {{item}}</view>
    </view>
    <view class="mini-card risk">
      <view class="mini-title">⚠ 风险</view>
      <view class="mini-text" wx:for="{{p.risks}}" wx:key="*this">• {{item}}</view>
    </view>
  </view>

  <view class="section-title">DNA 四维解析</view>
  <view class="glass-card dim4-card">
    <view class="dim4-row" wx:for="{{dim4}}" wx:key="name">
      <view class="dim4-top"><text>{{item.name}}</text><text class="dim4-tag">{{item.tag}} · {{item.pct}}%</text></view>
      <view class="score-bar"><view class="score-fill" style="width:{{item.pct}}%;"></view></view>
    </view>
  </view>

  <view class="bottom-actions">
    <view class="btn-ghost" bindtap="again">重新测试</view>
    <view class="btn-primary" bindtap="poster">生成海报</view>
  </view>
  <view class="bottom-actions single">
    <button class="btn-ghost" open-type="share" hover-class="none">分享给好友</button>
  </view>
  <view class="footer-note">TradeDNA · 发现交易基因 · 找到最适合你的交易体系</view>
  </view></view>
  <tabbar active="mine"/>
</view>

.tabbar-wrap{
  position:fixed;left:0;right:0;bottom:0;z-index:99;
  padding-bottom:env(safe-area-inset-bottom);
  background:linear-gradient(180deg,rgba(6,17,31,.55),rgba(4,12,22,.96) 38%,rgba(2,8,18,1));
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
}
.tabbar{
  display:flex;height:108rpx;align-items:center;justify-content:space-around;
  border-top:1rpx solid rgba(247,198,106,.18);
  position:relative;
}
.tabbar::before{
  content:"";position:absolute;left:10%;right:10%;top:0;height:2rpx;
  background:linear-gradient(90deg,transparent,rgba(247,198,106,.55),transparent);
}
.tab-item{
  flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:4rpx;color:#7692ad;
}
.tab-item.on{color:#f7c66a;}
.tab-ico{font-size:38rpx;line-height:1;filter:grayscale(.4) opacity(.7);}
.tab-item.on .tab-ico{filter:none;text-shadow:0 0 14rpx rgba(247,198,106,.7);}
.tab-text{font-size:21rpx;letter-spacing:.5rpx;font-weight:600;}
.tab-ico-mid{font-size:46rpx;}
